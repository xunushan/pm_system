# 目标管理系统 Service 本地开发环境变量
# 用法：cp .env.example .env，按需修改

# 服务端口（uvicorn 监听；/api/v1 与 /webhook 同在此端口）
API_PORT=8001

# 数据库（SQLite，唯一真相源）
DATABASE_URL=sqlite:///./data/pm.db

# Redis（超时监控 / 缓存 / Supervisor 巡检去重）
REDIS_URL=redis://localhost:6379/0

# OpenCode 智能体执行环境
# 全局 opencode serve 端口（方案 B：单进程 + 多 session，一个进程服务所有 workspace）
OPENCODE_SERVE_PORT=18800
# OPENCODE_BASE_URL 已由 OPENCODE_SERVE_PORT 接管，保留向后兼容
OPENCODE_BASE_URL=http://localhost:18800

# 飞书开放平台（留空则飞书相关功能不可用）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 飞书默认推送目标（个人 open_id 或群 chat_id；推卡 send_card 的 receive_id）
FEISHU_DEFAULT_CHAT_ID=

# H5 页面基址（pm 配置类指令生成预填链接用）
H5_BASE_URL=http://localhost:5173

# Supervisor 巡检开关
SUPERVISOR_ENABLED=true
