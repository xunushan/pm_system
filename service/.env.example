# 目标管理系统 Service 本地开发环境变量
# 用法：cp .env.example .env，按需修改

# 服务端口（uvicorn 监听；/api/v1 与 /webhook 同在此端口）
API_PORT=8001

# 数据库（SQLite，唯一真相源）
DATABASE_URL=sqlite:///./data/pm.db

# Redis（超时监控 / 缓存 / Supervisor 巡检去重）
REDIS_URL=redis://localhost:6379/0

# OpenCode 智能体执行环境
OPENCODE_BASE_URL=http://localhost:8080
AGENT_PORT_RANGE=10000-20000

# 飞书开放平台（留空则飞书相关功能不可用）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# H5 页面基址（pm 配置类指令生成预填链接用）
H5_BASE_URL=http://localhost:5173

# Supervisor 巡检开关
SUPERVISOR_ENABLED=true
